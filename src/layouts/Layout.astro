---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = "Adonyme — Système d'acquisition Source-to-Scale™ : Meta Ads, Outbound, Tunnel, CRM",
  description = "On accompagne les entreprises à générer un flux de rendez-vous qualifiés pour accélérer leur croissance — Publicité, Outbound & Agents IA.",
  canonical = "https://adonyme.com/",
} = Astro.props;

const schemaOrg = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://adonyme.com/#organization",
      "name": "Adonyme",
      "url": "https://adonyme.com",
      "logo": "https://adonyme.com/logo-adonyme.png",
      "description": "Agence d'automatisation de la prospection B2B par agents IA en France. Méthode Source-to-Scale™.",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "30 Boulevard de Sébastopol",
        "addressLocality": "Paris",
        "postalCode": "75004",
        "addressCountry": "FR"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "contact@adonyme.fr",
        "contactType": "customer service",
        "availableLanguage": "French"
      },
      "sameAs": [
        "https://www.linkedin.com/company/adonyme",
        "https://www.pappers.fr/entreprise/adonyme-992598003",
        "https://www.societe.com/societe/adonyme-992598003.html"
      ]
    },
    {
      "@type": "WebSite",
      "@id": "https://adonyme.com/#website",
      "url": "https://adonyme.com",
      "name": "Adonyme",
      "publisher": { "@id": "https://adonyme.com/#organization" }
    },
    {
      "@type": "Service",
      "@id": "https://adonyme.com/#service",
      "name": "Méthode Source-to-Scale™",
      "provider": { "@id": "https://adonyme.com/#organization" },
      "description": "Système complet d'acquisition B2B qui tourne en autonomie : Meta Ads, outbound multicanal, Source Intelligence, page de capture avec VSL, tunnel GHL, nurturing automatisé, scoring comportemental, warming avant call et mesure CAC vs LTV.",
      "areaServed": "FR",
      "serviceType": "Système d'acquisition B2B automatisé",
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Méthode Source-to-Scale™ — 8 étapes",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Fondations", "description": "Définition ICP, signaux d'achat et douleur centrale. Plan Source-to-Scale priorisé en 30 minutes." } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Attirer", "description": "Campagnes Meta Ads CBO TOFU/MOFU/BOFU en simultané. L'algorithme optimise en global." } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Source Intelligence", "description": "Identification et scraping de sources de données non exploitées, spécifiques au secteur et à l'ICP." } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Prospecter", "description": "Séquences email multicanal, LinkedIn outreach, SDR vocal IA. Enrichissement en cascade selon les signaux détectés. 5 à 7 touches sur 45 jours." } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Capturer", "description": "Page de capture + VSL 30-60s + formulaire. Chaque lead entre automatiquement dans le CRM GHL." } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Nurturing", "description": "Séquence email 30 jours automatisée. Pipeline CRM GHL. Scoring comportemental : email ouvert 3× → SMS dans l'heure." } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Convertir", "description": "Séquence anti no-show : warming progressif, témoignages, vidéo J+1. Le prospect vous connaît avant de décrocher." } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Mesurer", "description": "UTMs par canal, CAC vs LTV, reporting hebdomadaire. Vous savez où concentrer le budget." } }
        ]
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Pourquoi le lead magnet doit être derrière une page de capture ?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Un PDF envoyé directement ne génère rien. Derrière une page de capture avec une VSL de 30 à 60 secondes, vous capturez le contact, vous démarrez la relation, et vous déclenchez automatiquement la séquence CRM. Sans ça, vous offrez de la valeur sans rien récupérer en échange."
          }
        },
        {
          "@type": "Question",
          "name": "Comment fonctionne le scoring comportemental ?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Chaque action de votre prospect déclenche une réponse automatique. Email ouvert 3 fois → SMS dans l'heure. Clic sur la page RDV sans réservation → créneau proposé immédiatement. Le système détecte les signaux chauds et agit avant que l'intérêt retombe."
          }
        },
        {
          "@type": "Question",
          "name": "C'est quoi concrètement le warming avant le call ?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Entre la réservation et le call, le prospect reçoit une séquence progressive : confirmation, études de cas, témoignages, puis une vidéo qui on est J+1. Quand il décroche, il vous connaît déjà — il a vu vos résultats. Vous closez en 20 minutes, pas 60."
          }
        },
        {
          "@type": "Question",
          "name": "Pourquoi vous ne partez pas de bases Apollo comme tout le monde ?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Parce que vos concurrents prospectent exactement les mêmes contacts avec exactement les mêmes messages. On identifie des sources de données non exploitées, spécifiques à votre secteur. Et surtout — on n'enrichit pas tout le monde de la même façon. Si un signal d'achat est détecté sur un profil, on déclenche un enrichissement avancé : téléphone, LinkedIn, contexte entreprise. Si aucun signal, on ne dépense pas le budget. Vous ne travaillez que les profils qui arrivent en phase d'achat."
          }
        },
        {
          "@type": "Question",
          "name": "Comment vous mesurez que le système performe ?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "UTMs par canal, CAC vs LTV, taux de conversion à chaque étape du tunnel. Reporting hebdomadaire. Vous savez exactement d'où vient chaque client, quel canal convertit le mieux, et où concentrer le budget au mois 4."
          }
        },
        {
          "@type": "Question",
          "name": "Est-ce que vous gérez aussi la publicité Meta ?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Oui. On structure les campagnes en CBO avec des créas TOFU, MOFU et BOFU qui tournent en simultané. L'algorithme optimise en global — pas par adset. C'est ce qui permet de scaler le budget sans casser les performances."
          }
        }
      ]
    }
  ]
};
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="index, follow" />
    <meta name="google-site-verification" content="qpayeTZfWMEaxQK1RlXRh9Bs-4vModoxG37Y4iw7N6M" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Adonyme" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://adonyme.com/og-image.jpg" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="Adonyme" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://adonyme.com/og-image.jpg" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/logo-adonyme.png" />
    <link rel="apple-touch-icon" href="/logo-adonyme.png" />

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />
  </head>
  <body>
    <slot />
  </body>
</html>
