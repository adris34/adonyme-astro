---
import Layout from '../layouts/Layout.astro';
---

<Layout>

  <!-- HERO -->
  <section class="relative min-h-screen flex flex-col items-center justify-start pt-32 pb-0 overflow-hidden" style="background-color:#f4f5f6;">
    <div class="orb" style="background:#2563eb;width:600px;height:600px;top:-10%;right:-10%;opacity:0.07;"></div>
    <div class="orb" style="background:#2563eb;width:500px;height:500px;bottom:-10%;left:-10%;opacity:0.04;"></div>

    <div class="w-full max-w-6xl mx-auto px-8 relative z-10 flex flex-col items-center text-center">
      <!-- Badge -->
      <div class="inline-flex items-center px-6 py-2 rounded-full border mb-10 text-xs font-bold uppercase tracking-wider shadow-sm" style="border-color:rgba(37,99,235,0.2);background:rgba(37,99,235,0.05);color:#2563eb;">
        Le 1er système d'acquisition IA pensé pour le marché français
      </div>

      <h1 class="text-5xl md:text-7xl font-extrabold leading-tight mb-8 max-w-4xl" style="color:#0f172a;letter-spacing:-0.03em;">
        L'infrastructure qui remplace <span style="color:#2563eb;">votre acquisition.</span>
      </h1>

      <p class="text-xl md:text-2xl font-medium mb-8 max-w-3xl leading-relaxed" style="color:#475569;">
        Adonyme construit un écosystème d'agents IA sur-mesure — qui prospecte sur <strong class="font-extrabold italic" style="color:#0f172a;">des sources que personne n'exploite encore</strong>, automatise <strong class="font-extrabold italic" style="color:#0f172a;">chaque étape du cycle commercial</strong>, et vous livre <strong class="font-extrabold italic" style="color:#0f172a;">des revenus prévisibles</strong>. Sans équipe à gérer.
      </p>

      <a href="https://cal.com/acquisition-ai/decouverte" target="_blank" rel="noopener noreferrer"
        class="inline-flex items-center gap-3 px-12 py-5 rounded-2xl text-xl font-bold text-white mb-4 transition-transform hover:scale-105"
        style="background:#2563eb;box-shadow:0 20px 40px rgba(37,99,235,0.25);">
        Réserver mon audit gratuit →
      </a>
      <p class="text-sm font-bold" style="color:#94a3b8;">+50 startups, TPE et PME nous font confiance</p>
    </div>

    <!-- Marquee -->
    <div class="w-full mt-16 py-10 border-t border-b" style="background:#f8fafc;border-color:#e2e8f0;">
      <div class="w-full max-w-6xl mx-auto px-8">
        <h2 class="text-3xl md:text-4xl font-bold text-center mb-10" style="color:#0f172a;">Nos outils d'acquisition.</h2>
        <div class="relative overflow-hidden w-full h-16 flex items-center">
          <div class="absolute inset-y-0 left-0 w-20 z-10" style="background:linear-gradient(to right,#f8fafc,transparent);"></div>
          <div class="absolute inset-y-0 right-0 w-20 z-10" style="background:linear-gradient(to left,#f8fafc,transparent);"></div>
          <div class="marquee-track flex gap-4 items-center whitespace-nowrap">
            {["Scraping sur-mesure","Cold Email","SDR IA","LinkedIn Automation","Social Warming","Ringless Voicemail","WhatsApp Automation","Meta Ads","Google Ads","LinkedIn Ads","Enrichissement de données","Prise de RDV","Nurturing automatisé","Score de qualification","Campagnes SMS","Séquences multicanal","Agent IA 24h/24","CRM sur-mesure","Transcription d'appels","Hyper-personnalisation","Source Intelligence","Retargeting","Taboola","Outbrain",
             "Scraping sur-mesure","Cold Email","SDR IA","LinkedIn Automation","Social Warming","Ringless Voicemail","WhatsApp Automation","Meta Ads","Google Ads","LinkedIn Ads","Enrichissement de données","Prise de RDV","Nurturing automatisé","Score de qualification","Campagnes SMS","Séquences multicanal","Agent IA 24h/24","CRM sur-mesure","Transcription d'appels","Hyper-personnalisation","Source Intelligence","Retargeting","Taboola","Outbrain"].map((item) => (
              <div class="px-8 py-3 rounded-full text-sm font-bold flex-none" style="background:white;border:1px solid #e2e8f0;color:#0f172a;">
                {item}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROBLÈME -->
  <section class="py-24 relative overflow-hidden" style="background:#0f172a;">
    <div class="w-full max-w-6xl mx-auto px-8 relative z-10 max-w-4xl mx-auto text-center">
      <p class="text-xs font-bold uppercase tracking-widest mb-6" style="color:#2563eb;letter-spacing:0.15em;">Le problème</p>
      <h2 class="text-4xl md:text-6xl font-black mb-10 leading-tight" style="color:white;">
        La prospection manuelle est morte. <span class="italic" style="color:#2563eb;">Vous le savez déjà.</span>
      </h2>
      <p class="text-xl md:text-2xl leading-relaxed mb-8" style="color:#94a3b8;">
        Vos commerciaux passent 80% de leur temps sur des tâches répétitives. Vos campagnes de prospection B2B tournent sur les mêmes bases Apollo que vos concurrents. Vos séquences multicanal se ressemblent toutes. Et pendant ce temps, les deals partent ailleurs.
      </p>
      <p class="text-2xl md:text-3xl font-black" style="color:white;">
        Le problème n'est pas votre offre. <span class="font-extrabold italic" style="color:#2563eb;">C'est l'absence d'infrastructure.</span>
      </p>
    </div>
  </section>

  <!-- STATS -->
  <section class="py-24 border-t border-b" style="background:white;border-color:#e2e8f0;">
    <div class="w-full max-w-6xl mx-auto px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-12">
        {[
          { value: "412 000", label: "prospects générés via Meta & Google Ads" },
          { value: "4.9/5", label: "satisfaction client" },
          { value: "×15.6", label: "ROI moyen constaté" },
          { value: "+30", label: "secteurs d'activités accompagnés" },
        ].map((stat) => (
          <div class="flex flex-col items-center text-center">
            <div class="text-5xl md:text-7xl font-black mb-4" style="color:#0f172a;letter-spacing:-0.03em;">{stat.value}</div>
            <div class="text-xs uppercase font-bold tracking-widest text-center" style="color:#64748b;">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- MÉTHODE SOURCE-TO-SCALE -->
  <section class="py-24 relative overflow-hidden" style="background:#f4f5f6;">
    <div class="w-full max-w-6xl mx-auto px-8 relative z-10">
      <div class="max-w-2xl mb-16">
        <p class="text-xs font-bold uppercase tracking-widest mb-4" style="color:#2563eb;letter-spacing:0.15em;">La méthode Source-to-Scale™</p>
        <h2 class="text-4xl md:text-6xl font-black mb-4" style="color:#0f172a;">
          Le système qui tourne <span class="font-extrabold italic" style="color:#2563eb;">à votre place.</span>
        </h2>
        <p class="text-xl font-medium leading-relaxed" style="color:#64748b;">
          Là où les autres commencent par envoyer des emails, nous commençons par trouver une donnée que personne n'a encore exploitée.
        </p>
      </div>

      <div class="flex flex-col gap-6 max-w-4xl">
        {[
          { n:"01", title:"Diagnostic Process", desc:"On identifie le process commercial qui vous coûte le plus de temps et de deals. Cibles, canaux d'acquisition, sources de données disponibles. Vous repartez avec un plan d'automatisation concret en 30 minutes.", result:"Vous savez exactement où l'agent IA va intervenir." },
          { n:"02", title:"Source Intelligence", desc:"On ne rachète pas les mêmes bases de prospection que tout le monde. On scrape la donnée brute là où personne ne regarde encore — LeBonCoin, plateformes métier, LinkedIn, forums sectoriels. Données structurées et enrichies en interne.", result:"Vos prospects n'ont jamais été contactés par ce canal." },
          { n:"03", title:"Data Engineering", desc:"Enrichissement de données, scoring IA, nettoyage. Chaque prospect est automatiquement qualifié avant même le premier contact. Vous ne parlez qu'aux bons profils B2B, au bon moment.", result:"Zéro temps perdu sur des leads froids." },
          { n:"04", title:"Hyper-personnalisation & Déploiement", desc:"L'agent IA scrape le profil, rédige un message hyper-personnalisé selon l'ICP et l'envoie sur le bon canal. Prospection multicanal automatisée : LinkedIn, email, SMS, WhatsApp, SDR vocal IA. Humain dans le ton.", result:"Taux de réponse ×4 vs un message générique." },
          { n:"05", title:"Nurturing & Orchestration", desc:"Nurturing automatisé, qualification progressive, prise de RDV automatique par agent IA, injection CRM sans saisie manuelle. Reporting hebdomadaire. Votre infrastructure d'acquisition s'améliore chaque semaine.", result:"Vous recevez des RDV qualifiés. Vous closez." },
        ].map((step) => (
          <div class="flex items-start gap-8 p-8 rounded-3xl border" style="background:white;border-color:#e2e8f0;">
            <div class="text-6xl font-black flex-none leading-none" style="color:rgba(0,0,0,0.04);">{step.n}</div>
            <div>
              <h3 class="text-xl font-black mb-2" style="color:#0f172a;">{step.title}</h3>
              <p class="text-base font-medium leading-relaxed mb-4" style="color:#64748b;">{step.desc}</p>
              <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full" style="background:rgba(37,99,235,0.06);border:1px solid rgba(37,99,235,0.12);">
                <div class="w-1.5 h-1.5 rounded-full" style="background:#2563eb;"></div>
                <span class="text-sm font-bold" style="color:#2563eb;">{step.result}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PUBLICITÉ -->
  <section class="py-24 relative overflow-hidden" style="background:#f4f5f6;">
    <div class="w-full max-w-6xl mx-auto px-8 relative z-10">
      <div class="max-w-2xl mb-16">
        <p class="text-xs font-bold uppercase tracking-widest mb-4" style="color:#2563eb;letter-spacing:0.15em;">Acquisition payante</p>
        <h2 class="text-4xl md:text-6xl font-black mb-4" style="color:#0f172a;">
          La pub qui alimente <span class="font-extrabold italic" style="color:#2563eb;">le système.</span>
        </h2>
        <p class="text-xl font-medium leading-relaxed italic" style="color:#64748b;">
          On ne lance pas des campagnes publicitaires. On construit des tunnels d'acquisition rentables — du ciblage précis au lead B2B qualifié injecté dans votre CRM.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 mb-12">
        {[
          { title:"Creative Strategy", desc:"On définit précisément votre ICP — langage, douleurs, points de contact. Stratégie créative complète pour Meta Ads, Google Ads et LinkedIn Ads, testée chaque semaine." },
          { title:"Créatifs testés en continu", desc:"Copywriting IA, visuels A/B testés. Les créatifs qui performent scalent automatiquement. Les autres s'arrêtent." },
          { title:"Tunnel complet jusqu'au lead", desc:"Landing page optimisée · Formulaire de qualification automatique · Nurturing IA · Injection CRM. Du clic publicitaire à la prise de RDV qualifié — sans intervention humaine." },
        ].map((block) => (
          <div class="p-10 rounded-3xl border" style="background:white;border-color:#e2e8f0;">
            <h3 class="text-2xl font-black mb-4" style="color:#0f172a;">{block.title}</h3>
            <p class="text-lg font-medium leading-relaxed" style="color:#64748b;">{block.desc}</p>
          </div>
        ))}
      </div>

      <p class="text-center text-sm font-bold uppercase tracking-widest" style="color:#94a3b8;">
        Régies : Meta Ads · Google Ads · LinkedIn Ads · Taboola · Outbrain
      </p>
    </div>
  </section>

  <!-- TIMELINE -->
  <section class="py-24" style="background:white;">
    <div class="w-full max-w-6xl mx-auto px-8">
      <h2 class="text-4xl md:text-6xl font-black text-center mb-4" style="color:#0f172a;">
        De l'audit au système opérationnel <span class="italic" style="color:#2563eb;">en 48h.</span>
      </h2>
      <p class="text-center text-xl font-medium mb-20" style="color:#64748b;">Trois étapes. Pas de friction. Pas de formation interne requise.</p>

      <div class="flex flex-col md:flex-row gap-8 max-w-5xl mx-auto">
        {[
          { n:"01", title:"Audit 30 min", desc:"On analyse vos cibles, vos canaux et vos sources de données. On identifie le levier à fort ROI immédiat. Vous repartez avec un plan concret." },
          { n:"02", title:"Build & Déploiement", desc:"Construction de l'agent IA, configuration des séquences, branchement CRM. Le système est live en 48h." },
          { n:"03", title:"Scale & Optimisation", desc:"Reporting hebdomadaire, tests continus, nouveaux canaux. Le système s'améliore sans intervention." },
        ].map((step) => (
          <div class="flex-1 p-8 rounded-3xl border" style="background:#f8fafc;border-color:#e2e8f0;">
            <div class="text-sm font-black uppercase tracking-widest mb-3" style="color:#2563eb;">Étape {step.n}</div>
            <h3 class="text-2xl font-black mb-3" style="color:#0f172a;">{step.title}</h3>
            <p class="font-medium leading-relaxed" style="color:#64748b;">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SOCIAL PROOF -->
  <section class="py-24" style="background:#f4f5f6;">
    <div class="w-full max-w-6xl mx-auto px-8">
      <div class="text-center mb-16">
        <p class="text-xs font-bold uppercase tracking-widest mb-4" style="color:#2563eb;letter-spacing:0.15em;">Ils nous font confiance</p>
        <h2 class="text-4xl md:text-6xl font-black" style="color:#0f172a;">
          Des résultats, pas des <span class="font-extrabold italic" style="color:#2563eb;">promesses.</span>
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8 mb-16">
        {[
          { metric:"3 RDV/semaine", quote:"L'agent scrape LeBonCoin chaque matin, envoie un message personnalisé aux vendeurs, et me pose 3 RDV par semaine. Sans intervention de ma part.", name:"Marc D.", role:"Dirigeant — IMMO+" },
          { metric:"×4 taux de réponse", quote:"Taux de réponse LinkedIn multiplié par 4. Je n'aurais pas cru si je ne l'avais pas vu.", name:"Thomas B.", role:"CEO — TechScale" },
          { metric:"ROI J+7", quote:"Opérationnel en 48h. Le premier lead qualifié est tombé le lendemain. ROI positif dès la première semaine.", name:"Julie L.", role:"Fondatrice — Bloom" },
        ].map((t) => (
          <div class="p-10 rounded-3xl border relative" style="background:white;border-color:#e2e8f0;">
            <div class="absolute top-6 right-6 px-4 py-1.5 rounded-full text-sm font-black" style="background:rgba(37,99,235,0.08);color:#2563eb;">{t.metric}</div>
            <p class="text-lg font-medium leading-relaxed italic mb-8" style="color:#334155;">"{t.quote}"</p>
            <div>
              <div class="font-black" style="color:#0f172a;">{t.name}</div>
              <div class="text-sm font-medium" style="color:#94a3b8;">{t.role}</div>
            </div>
          </div>
        ))}
      </div>

      <div class="text-center mb-8">
        <h3 class="text-2xl font-black mb-8" style="color:#0f172a;">+30 secteurs d'activités accompagnés</h3>
      </div>
      <div class="relative overflow-hidden w-full h-16 flex items-center">
        <div class="absolute inset-y-0 left-0 w-20 z-10" style="background:linear-gradient(to right,#f4f5f6,transparent);"></div>
        <div class="absolute inset-y-0 right-0 w-20 z-10" style="background:linear-gradient(to left,#f4f5f6,transparent);"></div>
        <div class="marquee-track-slow flex gap-8 items-center whitespace-nowrap">
          {["Immobilier","Finance","E-commerce","SaaS","Retail","Industrie","Services B2B","Santé","Recrutement","Juridique",
            "Immobilier","Finance","E-commerce","SaaS","Retail","Industrie","Services B2B","Santé","Recrutement","Juridique",
            "Immobilier","Finance","E-commerce","SaaS","Retail","Industrie","Services B2B","Santé","Recrutement","Juridique"].map((s) => (
            <div class="px-10 py-3 rounded-full text-xl font-black flex-none" style="background:white;border:1px solid #e2e8f0;color:rgba(15,23,42,0.3);">{s}</div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-24" style="background:#f4f5f6;">
    <div class="w-full max-w-6xl mx-auto px-8 max-w-3xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-xs font-bold uppercase tracking-widest mb-4" style="color:#2563eb;letter-spacing:0.15em;">FAQ</p>
        <h2 class="text-4xl md:text-5xl font-black" style="color:#0f172a;">
          Les questions qu'on nous <span class="font-extrabold italic" style="color:#2563eb;">pose toujours.</span>
        </h2>
      </div>

      <div class="flex flex-col gap-4">
        {[
          { q:"Comment fonctionne votre système d'automatisation de la prospection B2B ?", a:"La méthode Source-to-Scale™ d'Adonyme fonctionne en 5 étapes : diagnostic du process, scraping des sources de données brutes, enrichissement IA, déploiement des agents multicanal (LinkedIn, email, SMS, WhatsApp, SDR vocal), puis nurturing et orchestration automatisés. Le tout est opérationnel en 48h." },
          { q:"En quoi vos agents IA sont différents des outils de prospection classiques ?", a:"Les outils classiques envoient les mêmes messages depuis les mêmes bases Apollo que vos concurrents. Nos agents IA vont chercher la donnée à la source — LeBonCoin, plateformes métier, LinkedIn — et construisent des séquences hyper-personnalisées sur des canaux sous-exploités. Résultat : taux de réponse ×4 en moyenne." },
          { q:"Combien de temps avant de voir des résultats ?", a:"Votre infrastructure d'acquisition automatisée est opérationnelle en 48h. Les premiers leads qualifiés arrivent dans la première semaine. Certains clients décrochent leur premier RDV le lendemain du déploiement." },
          { q:"Faut-il une équipe commerciale pour utiliser vos solutions ?", a:"Non. Le système d'agents IA tourne en autonomie complète — prospection, qualification, relances, prise de RDV. Vous recevez un reporting hebdomadaire avec les métriques clés. Votre seule intervention : closer les RDV qualifiés qu'on vous livre." },
        ].map((faq) => (
          <details class="rounded-2xl border p-8 group" style="background:white;border-color:#e2e8f0;">
            <summary class="text-lg font-black cursor-pointer list-none flex items-center justify-between" style="color:#0f172a;">
              {faq.q}
              <span class="text-2xl font-light ml-4 flex-none" style="color:#2563eb;">+</span>
            </summary>
            <p class="mt-6 text-lg font-medium leading-relaxed" style="color:#64748b;">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="py-24" style="background:#f4f5f6;">
    <div class="w-full max-w-6xl mx-auto px-8">
      <div class="p-12 md:p-20 rounded-[48px] text-center relative overflow-hidden" style="background:#0f172a;">
        <div class="absolute inset-0" style="background:radial-gradient(circle at center,rgba(37,99,235,0.15) 0%,transparent 70%);"></div>
        <div class="relative z-10 max-w-3xl mx-auto">
          <h2 class="text-4xl md:text-7xl font-black mb-8 leading-tight" style="color:white;letter-spacing:-0.03em;">
            Combien de prospects perdez-vous <span class="italic" style="color:#2563eb;">chaque jour ?</span>
          </h2>
          <p class="text-xl md:text-2xl font-medium leading-relaxed mb-8" style="color:#94a3b8;">
            Audit gratuit de 30 minutes. On analyse votre process d'acquisition, on identifie vos canaux de prospection B2B sous-exploités, on repart avec un plan d'automatisation concret — et souvent une démo live de la méthode Source-to-Scale™ appliquée à votre cible.
          </p>
          <a href="https://cal.com/acquisition-ai/decouverte" target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center gap-3 px-12 py-5 rounded-2xl text-xl font-bold text-white mb-4 transition-transform hover:scale-105"
            style="background:#2563eb;box-shadow:0 20px 40px rgba(37,99,235,0.3);">
            Réserver mon audit gratuit →
          </a>
          <p class="text-sm font-bold" style="color:#475569;">Sans engagement · 30 minutes · 3 créneaux disponibles cette semaine</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="py-16 border-t" style="background:#f4f5f6;border-color:#e2e8f0;">
    <div class="w-full max-w-6xl mx-auto px-8">
      <div class="flex flex-col md:flex-row justify-between items-center gap-10">
        <div>
          <span class="text-3xl font-black" style="color:#0f172a;letter-spacing:-0.03em;">ADONYME<span style="color:#2563eb;">.</span></span>
          <p class="text-sm font-medium mt-2 max-w-xs" style="color:#64748b;">
            La méthode Source-to-Scale™ — automatisation de la prospection B2B et acquisition clients par agents IA en France.
          </p>
        </div>

        <div class="flex flex-wrap justify-center gap-8 text-sm font-semibold" style="color:#64748b;">
          <a href="#" class="hover:text-blue-600 transition-colors uppercase tracking-widest">Méthode</a>
          <a href="#" class="hover:text-blue-600 transition-colors uppercase tracking-widest">Résultats</a>
          <a href="#" class="hover:text-blue-600 transition-colors uppercase tracking-widest">Contact</a>
          <a href="/mentions-legales" class="hover:text-blue-600 transition-colors uppercase tracking-widest">Mentions légales</a>
        </div>

        <div class="flex flex-col items-end gap-2">
          <div class="flex gap-6 text-sm" style="color:#94a3b8;">
            <a href="/politique-de-confidentialite" class="hover:text-gray-700 transition-colors">Politique de confidentialité</a>
            <a href="/mentions-legales" class="hover:text-gray-700 transition-colors">Mentions légales</a>
          </div>
          <div class="text-xs font-mono" style="color:rgba(148,163,184,0.4);">© 2026 Adonyme.</div>
        </div>
      </div>
    </div>
  </footer>

</Layout>

<style>
  .marquee-track {
    animation: marquee 24s linear infinite;
  }
  .marquee-track-slow {
    animation: marquee 30s linear infinite;
  }
  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  details[open] summary span {
    transform: rotate(45deg);
    display: inline-block;
  }
</style>
