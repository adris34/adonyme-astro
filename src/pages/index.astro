---
import Layout from '../layouts/Layout.astro';
---

<Layout>

  <!-- HERO -->
  <section style="background:#f4f5f6;min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:flex-start;padding-top:120px;padding-bottom:0;position:relative;overflow:hidden;">
    <div style="position:absolute;width:600px;height:600px;top:-10%;right:-10%;background:#2563eb;border-radius:9999px;filter:blur(120px);opacity:0.07;pointer-events:none;"></div>
    <div style="position:absolute;width:500px;height:500px;bottom:-10%;left:-10%;background:#2563eb;border-radius:9999px;filter:blur(120px);opacity:0.04;pointer-events:none;"></div>

    <div style="width:100%;max-width:900px;margin:0 auto;padding:0 2rem;display:flex;flex-direction:column;align-items:center;text-align:center;position:relative;z-index:10;">

      <div style="display:inline-flex;align-items:center;padding:6px 20px;border-radius:9999px;border:1px solid rgba(37,99,235,0.2);background:rgba(37,99,235,0.05);color:#2563eb;font-size:11px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:40px;">
        Le 1er système d'acquisition IA pensé pour le marché français
      </div>

      <h1 style="font-size:clamp(40px,6vw,72px);font-weight:800;line-height:1.08;letter-spacing:-0.03em;color:#0f172a;margin-bottom:28px;">
        L'infrastructure qui remplace <span style="color:#2563eb;">votre acquisition.</span>
      </h1>

      <p style="font-size:clamp(17px,2vw,21px);font-weight:500;line-height:1.7;color:#475569;max-width:680px;margin-bottom:36px;">
        Adonyme construit un écosystème d'agents IA sur-mesure — qui prospecte sur <strong style="font-weight:800;font-style:italic;color:#0f172a;">des sources que personne n'exploite encore</strong>, automatise <strong style="font-weight:800;font-style:italic;color:#0f172a;">chaque étape du cycle commercial</strong>, et vous livre <strong style="font-weight:800;font-style:italic;color:#0f172a;">des revenus prévisibles</strong>. Sans équipe à gérer.
      </p>

      <a href="https://cal.com/acquisition-ai/decouverte" target="_blank" rel="noopener noreferrer"
        style="display:inline-flex;align-items:center;gap:12px;padding:18px 48px;border-radius:16px;font-size:18px;font-weight:700;color:white;background:#2563eb;box-shadow:0 20px 40px rgba(37,99,235,0.25);text-decoration:none;margin-bottom:14px;transition:transform 0.2s;"
        onmouseover="this.style.transform='scale(1.03)'" onmouseout="this.style.transform='scale(1)'">
        Réserver mon audit gratuit →
      </a>
      <p style="font-size:13px;font-weight:700;color:#94a3b8;">+50 startups, TPE et PME nous font confiance</p>
    </div>

    <!-- Marquee -->
    <div style="width:100%;margin-top:64px;padding:32px 0;background:#f0f2f5;border-top:1px solid #e2e8f0;border-bottom:1px solid #e2e8f0;">
      <h2 style="font-size:clamp(22px,3vw,32px);font-weight:800;text-align:center;color:#0f172a;margin-bottom:36px;">Nos outils d'acquisition.</h2>
      <div style="position:relative;overflow:hidden;width:100%;height:56px;display:flex;align-items:center;">
        <div style="position:absolute;inset-y:0;left:0;width:80px;background:linear-gradient(to right,#f0f2f5,transparent);z-index:10;"></div>
        <div style="position:absolute;inset-y:0;right:0;width:80px;background:linear-gradient(to left,#f0f2f5,transparent);z-index:10;"></div>
        <div class="marquee-track" style="display:flex;gap:14px;align-items:center;white-space:nowrap;">
          {["Scraping sur-mesure","Cold Email","SDR IA","LinkedIn Automation","Social Warming","Ringless Voicemail","WhatsApp Automation","Meta Ads","Google Ads","LinkedIn Ads","Enrichissement de données","Prise de RDV","Nurturing automatisé","Score de qualification","Campagnes SMS","Séquences multicanal","Agent IA 24h/24","CRM sur-mesure","Transcription d'appels","Hyper-personnalisation","Source Intelligence","Retargeting","Taboola","Outbrain",
           "Scraping sur-mesure","Cold Email","SDR IA","LinkedIn Automation","Social Warming","Ringless Voicemail","WhatsApp Automation","Meta Ads","Google Ads","LinkedIn Ads","Enrichissement de données","Prise de RDV","Nurturing automatisé","Score de qualification","Campagnes SMS","Séquences multicanal","Agent IA 24h/24","CRM sur-mesure","Transcription d'appels","Hyper-personnalisation","Source Intelligence","Retargeting","Taboola","Outbrain"].map(item => (
            <div style="padding:10px 28px;border-radius:9999px;background:white;border:1px solid #e2e8f0;font-size:14px;font-weight:700;color:#0f172a;flex-shrink:0;">{item}</div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- PROBLÈME -->
  <section style="padding:96px 0;background:#0f172a;position:relative;overflow:hidden;">
    <div style="position:absolute;inset:0;background:radial-gradient(circle at 30% 50%,rgba(37,99,235,0.08),transparent 70%);"></div>
    <div style="max-width:800px;margin:0 auto;padding:0 2rem;text-align:center;position:relative;z-index:10;">
      <p style="font-size:11px;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:#2563eb;margin-bottom:20px;">Le problème</p>
      <h2 style="font-size:clamp(32px,5vw,60px);font-weight:900;line-height:1.1;letter-spacing:-0.02em;color:white;margin-bottom:32px;">
        La prospection manuelle est morte. <span style="color:#2563eb;font-style:italic;">Vous le savez déjà.</span>
      </h2>
      <p style="font-size:clamp(16px,1.8vw,20px);line-height:1.7;color:#94a3b8;font-weight:500;margin-bottom:28px;">
        Vos commerciaux passent 80% de leur temps sur des tâches répétitives. Vos campagnes de prospection B2B tournent sur les mêmes bases Apollo que vos concurrents. Vos séquences multicanal se ressemblent toutes. Et pendant ce temps, les deals partent ailleurs.
      </p>
      <p style="font-size:clamp(18px,2vw,26px);font-weight:900;color:white;">
        Le problème n'est pas votre offre. <span style="color:#2563eb;font-style:italic;font-weight:800;">C'est l'absence d'infrastructure.</span>
      </p>
    </div>
  </section>

  <!-- STATS -->
  <section style="padding:80px 0;background:white;border-top:1px solid #e2e8f0;border-bottom:1px solid #e2e8f0;">
    <div style="max-width:1200px;margin:0 auto;padding:0 2rem;">
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:40px;">
        {[
          { value: "412 000", label: "prospects générés via Meta & Google Ads" },
          { value: "4.9/5", label: "satisfaction client" },
          { value: "×15.6", label: "ROI moyen constaté" },
          { value: "+30", label: "secteurs d'activités accompagnés" },
        ].map(stat => (
          <div style="display:flex;flex-direction:column;align-items:center;text-align:center;">
            <div style="font-size:clamp(40px,5vw,72px);font-weight:900;color:#0f172a;letter-spacing:-0.03em;margin-bottom:12px;white-space:nowrap;">{stat.value}</div>
            <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.15em;color:#64748b;text-align:center;">{stat.label}</div>
            <div style="width:40%;height:2px;background:rgba(37,99,235,0.15);margin-top:20px;border-radius:9999px;"></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- MÉTHODE SOURCE-TO-SCALE -->
  <section style="padding:96px 0;background:#f4f5f6;position:relative;overflow:hidden;">
    <div style="max-width:1200px;margin:0 auto;padding:0 2rem;position:relative;z-index:10;">
      <div style="max-width:600px;margin-bottom:60px;">
        <p style="font-size:11px;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:#2563eb;margin-bottom:14px;">La méthode Source-to-Scale™</p>
        <h2 style="font-size:clamp(32px,4.5vw,56px);font-weight:900;line-height:1.1;letter-spacing:-0.02em;color:#0f172a;margin-bottom:16px;">
          Le système qui tourne <span style="color:#2563eb;font-style:italic;font-weight:800;">à votre place.</span>
        </h2>
        <p style="font-size:18px;font-weight:500;line-height:1.65;color:#64748b;">
          Là où les autres commencent par envoyer des emails, nous commençons par trouver une donnée que personne n'a encore exploitée.
        </p>
      </div>

      <div style="display:flex;flex-direction:column;gap:20px;max-width:800px;position:relative;" id="steps-container">
        <div style="position:absolute;left:27px;top:0;bottom:0;width:2px;background:#e2e8f0;z-index:0;">
          <div id="progress-line" style="width:100%;height:0%;background:#2563eb;box-shadow:0 0 12px rgba(37,99,235,0.5);transition:height 0.05s linear;"></div>
        </div>

        {[
          { n:"01", icon:"🔍", title:"Diagnostic Process", desc:"On identifie le process commercial qui vous coûte le plus de temps et de deals. Cibles, canaux d'acquisition, sources de données disponibles. Vous repartez avec un plan d'automatisation concret en 30 minutes.", result:"Vous savez exactement où l'agent IA va intervenir." },
          { n:"02", icon:"🗄️", title:"Source Intelligence", desc:"On ne rachète pas les mêmes bases de prospection que tout le monde. On scrape la donnée brute là où personne ne regarde encore — LeBonCoin, plateformes métier, LinkedIn, forums sectoriels. Données structurées et enrichies en interne.", result:"Vos prospects n'ont jamais été contactés par ce canal." },
          { n:"03", icon:"📊", title:"Data Engineering", desc:"Enrichissement de données, scoring IA, nettoyage. Chaque prospect est automatiquement qualifié avant même le premier contact. Vous ne parlez qu'aux bons profils B2B, au bon moment.", result:"Zéro temps perdu sur des leads froids." },
          { n:"04", icon:"⚡", title:"Hyper-personnalisation & Déploiement", desc:"L'agent IA scrape le profil, rédige un message hyper-personnalisé selon l'ICP et l'envoie sur le bon canal. Prospection multicanal automatisée : LinkedIn, email, SMS, WhatsApp, SDR vocal IA. Humain dans le ton.", result:"Taux de réponse ×4 vs un message générique." },
          { n:"05", icon:"📡", title:"Nurturing & Orchestration", desc:"Nurturing automatisé, qualification progressive, prise de RDV automatique par agent IA, injection CRM sans saisie manuelle. Reporting hebdomadaire. Votre infrastructure d'acquisition s'améliore chaque semaine.", result:"Vous recevez des RDV qualifiés. Vous closez." },
        ].map(step => (
          <div style="display:flex;align-items:flex-start;gap:28px;padding:28px 28px 28px 20px;border-radius:24px;border:1px solid #e2e8f0;background:white;position:relative;z-index:1;">
            <div style="font-size:52px;font-weight:900;color:rgba(0,0,0,0.04);min-width:56px;line-height:1;flex-shrink:0;">{step.n}</div>
            <div style="flex:1;">
              <div style="display:flex;align-items:center;gap:12px;margin-bottom:10px;">
                <div style="width:36px;height:36px;border-radius:10px;background:rgba(37,99,235,0.08);display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;">{step.icon}</div>
                <h3 style="font-size:18px;font-weight:800;color:#0f172a;">{step.title}</h3>
              </div>
              <p style="font-size:14px;font-weight:500;line-height:1.65;color:#64748b;margin-bottom:14px;">{step.desc}</p>
              <div style="display:inline-flex;align-items:center;gap:8px;padding:6px 14px;border-radius:9999px;background:rgba(37,99,235,0.06);border:1px solid rgba(37,99,235,0.12);">
                <div style="width:6px;height:6px;border-radius:9999px;background:#2563eb;flex-shrink:0;"></div>
                <span style="font-size:13px;font-weight:700;color:#2563eb;">{step.result}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PUBLICITÉ -->
  <section style="padding:96px 0;background:#f4f5f6;position:relative;overflow:hidden;">
    <div style="max-width:1200px;margin:0 auto;padding:0 2rem;position:relative;z-index:10;">
      <div style="max-width:600px;margin-bottom:56px;">
        <p style="font-size:11px;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:#2563eb;margin-bottom:14px;">Acquisition payante</p>
        <h2 style="font-size:clamp(32px,4.5vw,56px);font-weight:900;line-height:1.1;letter-spacing:-0.02em;color:#0f172a;margin-bottom:16px;">
          La pub qui alimente <span style="color:#2563eb;font-style:italic;font-weight:800;">le système.</span>
        </h2>
        <p style="font-size:18px;font-weight:500;line-height:1.65;color:#64748b;font-style:italic;">
          On ne lance pas des campagnes publicitaires. On construit des tunnels d'acquisition rentables — du ciblage précis au lead B2B qualifié injecté dans votre CRM.
        </p>
      </div>

      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-bottom:40px;">
        {[
          { icon:"🎯", title:"Creative Strategy", desc:"On définit précisément votre ICP — langage, douleurs, points de contact. Stratégie créative complète pour Meta Ads, Google Ads et LinkedIn Ads, testée chaque semaine." },
          { icon:"✏️", title:"Créatifs testés en continu", desc:"Copywriting IA, visuels A/B testés. Les créatifs qui performent scalent automatiquement. Les autres s'arrêtent." },
          { icon:"📈", title:"Tunnel complet jusqu'au lead", desc:"Landing page optimisée · Formulaire de qualification automatique · Nurturing IA · Injection CRM. Du clic publicitaire à la prise de RDV qualifié — sans intervention humaine." },
        ].map(block => (
          <div style="padding:36px;border-radius:24px;border:1px solid #e2e8f0;background:white;">
            <div style="width:48px;height:48px;border-radius:14px;background:rgba(37,99,235,0.08);display:flex;align-items:center;justify-content:center;font-size:20px;margin-bottom:20px;">{block.icon}</div>
            <h3 style="font-size:20px;font-weight:800;color:#0f172a;margin-bottom:12px;">{block.title}</h3>
            <p style="font-size:15px;font-weight:500;line-height:1.65;color:#64748b;">{block.desc}</p>
          </div>
        ))}
      </div>

      <p style="text-align:center;font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:0.15em;color:#94a3b8;">
        Régies : Meta Ads · Google Ads · LinkedIn Ads · Taboola · Outbrain
      </p>
    </div>
  </section>

  <!-- TIMELINE -->
  <section style="padding:96px 0;background:white;">
    <div style="max-width:1200px;margin:0 auto;padding:0 2rem;">
      <h2 style="font-size:clamp(28px,4vw,52px);font-weight:900;text-align:center;letter-spacing:-0.02em;color:#0f172a;margin-bottom:12px;">
        De l'audit au système opérationnel <span style="color:#2563eb;font-style:italic;">en 48h.</span>
      </h2>
      <p style="text-align:center;font-size:17px;font-weight:500;color:#64748b;margin-bottom:80px;">Trois étapes. Pas de friction. Pas de formation interne requise.</p>

      <div style="position:relative;max-width:900px;margin:0 auto;" id="timeline-container">
        <!-- Ligne centrale -->
        <div style="position:absolute;left:50%;top:0;bottom:0;width:2px;background:#e2e8f0;transform:translateX(-50%);">
          <div id="timeline-line" style="width:100%;height:0%;background:#2563eb;box-shadow:0 0 12px rgba(37,99,235,0.5);transition:height 0.05s linear;"></div>
        </div>

        {[
          { n:"01", icon:"⚡", title:"Audit 30 min", desc:"On analyse vos cibles, vos canaux et vos sources de données. On identifie le levier à fort ROI immédiat. Vous repartez avec un plan concret.", right:true },
          { n:"02", icon:"🕐", title:"Build & Déploiement", desc:"Construction de l'agent IA, configuration des séquences, branchement CRM. Le système est live en 48h.", right:false },
          { n:"03", icon:"✅", title:"Scale & Optimisation", desc:"Reporting hebdomadaire, tests continus, nouveaux canaux. Le système s'améliore sans intervention.", right:true },
        ].map((step, i) => (
          <div style={`display:flex;align-items:center;margin-bottom:80px;position:relative;justify-content:${step.right ? 'flex-end' : 'flex-start'};`}>
            <!-- Dot central -->
            <div style="position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);width:14px;height:14px;border-radius:9999px;background:#2563eb;border:3px solid white;box-shadow:0 0 0 3px rgba(37,99,235,0.2);z-index:10;"></div>

            <div style={`width:45%;padding:32px;border-radius:24px;background:#f8fafc;border:1px solid #e2e8f0;${step.right ? 'text-align:right;' : ''}`}>
              <div style={`width:44px;height:44px;border-radius:12px;background:rgba(37,99,235,0.08);display:flex;align-items:center;justify-content:center;font-size:20px;margin-bottom:16px;${step.right ? 'margin-left:auto;' : ''}`}>{step.icon}</div>
              <p style="font-size:11px;font-weight:800;letter-spacing:0.12em;text-transform:uppercase;color:#2563eb;margin-bottom:6px;">Étape {step.n}</p>
              <h3 style="font-size:22px;font-weight:900;color:#0f172a;margin-bottom:10px;">{step.title}</h3>
              <p style="font-size:14px;font-weight:500;line-height:1.65;color:#64748b;">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SOCIAL PROOF -->
  <section style="padding:96px 0;background:#f4f5f6;">
    <div style="max-width:1200px;margin:0 auto;padding:0 2rem;">
      <div style="text-align:center;margin-bottom:56px;">
        <p style="font-size:11px;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:#2563eb;margin-bottom:14px;">Ils nous font confiance</p>
        <h2 style="font-size:clamp(28px,4vw,52px);font-weight:900;letter-spacing:-0.02em;color:#0f172a;">
          Des résultats, pas des <span style="color:#2563eb;font-style:italic;font-weight:800;">promesses.</span>
        </h2>
      </div>

      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-bottom:64px;">
        {[
          { metric:"3 RDV/semaine", quote:"L'agent scrape LeBonCoin chaque matin, envoie un message personnalisé avec ma photo aux vendeurs, et me pose 3 RDV par semaine. Sans intervention de ma part.", name:"Marc D.", role:"Dirigeant — IMMO+", initials:"MD" },
          { metric:"×4 taux de réponse", quote:"Taux de réponse LinkedIn multiplié par 4 depuis qu'on envoie des images générées avec la photo du prospect. Je n'aurais pas cru si je ne l'avais pas vu.", name:"Thomas B.", role:"CEO — TechScale", initials:"TB" },
          { metric:"ROI J+7", quote:"Opérationnel en 48h. Le premier lead qualifié est tombé le lendemain. ROI positif dès la première semaine.", name:"Julie L.", role:"Fondatrice — Bloom", initials:"JL" },
        ].map(t => (
          <div style="padding:32px;border-radius:24px;border:1px solid #e2e8f0;background:white;position:relative;">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:20px;">
              <div style="font-size:36px;color:rgba(37,99,235,0.1);line-height:1;">"</div>
              <div style="padding:5px 14px;border-radius:9999px;background:rgba(37,99,235,0.08);font-size:12px;font-weight:800;color:#2563eb;">{t.metric}</div>
            </div>
            <p style="font-size:14px;font-weight:500;line-height:1.7;color:#334155;font-style:italic;margin-bottom:24px;">"{t.quote}"</p>
            <div style="display:flex;align-items:center;gap:12px;">
              <div style="width:40px;height:40px;border-radius:9999px;background:rgba(37,99,235,0.1);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:800;color:#2563eb;flex-shrink:0;">{t.initials}</div>
              <div>
                <div style="font-size:14px;font-weight:800;color:#0f172a;">{t.name}</div>
                <div style="font-size:12px;font-weight:500;color:#94a3b8;">{t.role}</div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <h3 style="font-size:22px;font-weight:900;text-align:center;color:#0f172a;margin-bottom:32px;">+30 secteurs d'activités accompagnés</h3>
      <div style="position:relative;overflow:hidden;width:100%;height:56px;display:flex;align-items:center;">
        <div style="position:absolute;inset-y:0;left:0;width:80px;background:linear-gradient(to right,#f4f5f6,transparent);z-index:10;"></div>
        <div style="position:absolute;inset-y:0;right:0;width:80px;background:linear-gradient(to left,#f4f5f6,transparent);z-index:10;"></div>
        <div class="marquee-track-slow" style="display:flex;gap:28px;align-items:center;white-space:nowrap;">
          {["Immobilier","Finance","E-commerce","SaaS","Retail","Industrie","Services B2B","Santé","Recrutement","Juridique",
            "Immobilier","Finance","E-commerce","SaaS","Retail","Industrie","Services B2B","Santé","Recrutement","Juridique",
            "Immobilier","Finance","E-commerce","SaaS","Retail","Industrie","Services B2B","Santé","Recrutement","Juridique"].map(s => (
            <div style="padding:10px 36px;border-radius:9999px;background:white;border:1px solid #e2e8f0;font-size:18px;font-weight:900;color:rgba(15,23,42,0.25);flex-shrink:0;">{s}</div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section style="padding:96px 0;background:#f4f5f6;">
    <div style="max-width:720px;margin:0 auto;padding:0 2rem;">
      <div style="text-align:center;margin-bottom:56px;">
        <p style="font-size:11px;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:#2563eb;margin-bottom:14px;">FAQ</p>
        <h2 style="font-size:clamp(28px,4vw,46px);font-weight:900;letter-spacing:-0.02em;color:#0f172a;">
          Les questions qu'on nous <span style="color:#2563eb;font-style:italic;font-weight:800;">pose toujours.</span>
        </h2>
      </div>

      <div style="display:flex;flex-direction:column;gap:12px;">
        {[
          { q:"Comment fonctionne votre système d'automatisation de la prospection B2B ?", a:"La méthode Source-to-Scale™ d'Adonyme fonctionne en 5 étapes : diagnostic du process, scraping des sources de données brutes, enrichissement IA, déploiement des agents multicanal (LinkedIn, email, SMS, WhatsApp, SDR vocal), puis nurturing et orchestration automatisés. Le tout est opérationnel en 48h." },
          { q:"En quoi vos agents IA sont différents des outils de prospection classiques ?", a:"Les outils classiques envoient les mêmes messages depuis les mêmes bases Apollo que vos concurrents. Nos agents IA vont chercher la donnée à la source — LeBonCoin, plateformes métier, LinkedIn — et construisent des séquences hyper-personnalisées sur des canaux sous-exploités. Résultat : taux de réponse ×4 en moyenne." },
          { q:"Combien de temps avant de voir des résultats ?", a:"Votre infrastructure d'acquisition automatisée est opérationnelle en 48h. Les premiers leads qualifiés arrivent dans la première semaine. Certains clients décrochent leur premier RDV le lendemain du déploiement." },
